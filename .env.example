# Copy to .env for local dev. On Railway, set these as service Variables instead.

# Postgres connection string (Railway injects DATABASE_URL automatically when you
# link the Postgres plugin — you usually don't set this by hand on Railway).
DATABASE_URL=postgresql://user:pass@localhost:5432/mellovibes

# Secret used to sign login tokens. Use a long random string.
JWT_SECRET=replace-with-a-long-random-string

# Which frontend origin(s) may call this API (comma-separated). Use your Netlify URL.
FRONTEND_ORIGIN=https://mellovibes.io,https://www.mellovibes.io

# Seed admin account (created on first boot if it doesn't exist)
ADMIN_USERNAME=mello
ADMIN_PASSWORD=change-this
ADMIN_NAME=Mello

# Jellyfin server (lets the API hand out tokens so creds aren't in the frontend)
JELLYFIN_URL=https://casaos.tailb5d22.ts.net
JELLYFIN_USERNAME=romellom
JELLYFIN_PASSWORD=your-jellyfin-password
